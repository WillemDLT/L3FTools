<Bindings>
    <!--
        BINDING_HEADER_/BINDING_NAME_ globals MUST be set before WoW's
        Key Bindings UI registers the binding below, or the row falls
        into the generic "Other" category with the raw label
        "HEADER_L3FTOOLS". Setting them in Core.lua's top-level was
        too late on TBC Anniversary - the binding gets categorized
        at the moment Bindings.xml is parsed, which seems to happen
        before .toc-listed Lua files run.

        <Script file="..."/> sources BindingHeaders.lua at the exact
        moment this XML is being parsed - earlier than any other
        Lua we can run.
    -->
    <Script file="BindingHeaders.lua"/>
    <Binding name="L3FTOOLS_MOUSEOVERMARK" runOnUp="true" header="L3FTOOLS">
        if L3FTools then L3FTools.mouseoverHeld = keystate == "down" end
    </Binding>
</Bindings>
