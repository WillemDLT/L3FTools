<Bindings>
    <!--
        category="L3FTools" is the attribute working addons (Baganator,
        WeakAuras, ...) use. Unlike header="..." which needs a matching
        BINDING_HEADER_<X> global set BEFORE parse time (which doesn't
        seem to work on TBC Anniversary), category takes the literal
        attribute value as the display name and slots the binding under
        WoW's built-in "AddOns" auto-group. header= is kept as a fallback
        in case some client version ignores category.
    -->
    <Binding name="L3FTOOLS_MOUSEOVERMARK" runOnUp="true" header="L3FTOOLS" category="L3FTools">
        if L3FTools then L3FTools.mouseoverHeld = keystate == "down" end
    </Binding>
</Bindings>
